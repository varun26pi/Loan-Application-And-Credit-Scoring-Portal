# ─────────────────────────────────────────────────────────────────────────────
# FinServe — Environment Variables Reference
# Copy this file to .env.local and fill in your real values.
# NEXT_PUBLIC_ vars are exposed to the browser. Never add secrets here.
# Server-only vars (no prefix) go in Lambda environment variables ONLY.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Region (guide: ap-south-1) ───────────────────────────────────────────
NEXT_PUBLIC_AWS_REGION=ap-south-1

# ── Amazon Cognito (guide Phase 3 / section 4.1) ─────────────────────────────
# Format: ap-south-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
# Format: 26-character alphanumeric string
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── API Gateway (guide Phase 8 / section 9.5) ────────────────────────────────
# Format: https://XXXXXXXXXX.execute-api.ap-south-1.amazonaws.com/dev
NEXT_PUBLIC_API_GATEWAY_URL=https://XXXXXXXXXX.execute-api.ap-south-1.amazonaws.com/dev

# ── Amazon S3 (guide Phase 5 / section 6.1) ──────────────────────────────────
# Format: finserve-loan-documents-<your-account-id>
NEXT_PUBLIC_S3_BUCKET=finserve-loan-documents-123456789012

# ── Amazon CloudFront (guide Phase 13 / section 14.1) ────────────────────────
# Format: https://XXXXXXXXXXXX.cloudfront.net
NEXT_PUBLIC_CLOUDFRONT_URL=https://XXXXXXXXXXXX.cloudfront.net

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY VARIABLES — Add these to Lambda environment variables in AWS
# Console, NOT to .env.local (they are not needed by the Next.js frontend).
# Shown here for reference only (guide section 8.2).
# ─────────────────────────────────────────────────────────────────────────────

# REGION=ap-south-1
# COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
# COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# DYNAMODB_USERS_TABLE=finserve-users
# DYNAMODB_APPLICATIONS_TABLE=finserve-applications
# DYNAMODB_DOCUMENTS_TABLE=finserve-documents
# DYNAMODB_AUDIT_TABLE=finserve-audit-logs
# DYNAMODB_OTP_TABLE=finserve-otp-store
# SNS_APPLICATION_UPDATES_TOPIC=arn:aws:sns:ap-south-1:123456789012:finserve-app-updates
# SNS_OTP_TOPIC=arn:aws:sns:ap-south-1:123456789012:finserve-otp
# SES_FROM_EMAIL=noreply@finserve.in
# CLOUDTRAIL_BUCKET=finserve-cloudtrail-logs-123456789012
# TEXTRACT_SNS_TOPIC=arn:aws:sns:ap-south-1:123456789012:finserve-textract-complete
# TEXTRACT_SNS_ROLE_ARN=arn:aws:iam::123456789012:role/finserve-textract-sns-role
